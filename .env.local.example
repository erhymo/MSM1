# =====================================================
# MSM1 Environment Variables
# =====================================================

# -----------------------------------------------------
# Firebase
# -----------------------------------------------------

NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# -----------------------------------------------------
# Firebase Admin (server-side)
# -----------------------------------------------------

FIREBASE_ADMIN_PROJECT_ID=your-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk@your-project-id.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# -----------------------------------------------------
# Market Data APIs
# -----------------------------------------------------

# Price provider
PRICE_PROVIDER=yahoo-chart
PRICE_PROVIDER_BASE_URL=https://query2.finance.yahoo.com/v8/finance/chart
PRICE_PROVIDER_TIMEOUT_MS=12000
PRICE_PROVIDER_USER_AGENT="Mozilla/5.0 (compatible; MSM1/1.0)"

# Yahoo Finance (optional alternate integration, e.g. RapidAPI wrapper)
RAPIDAPI_KEY=your_rapidapi_key
RAPIDAPI_HOST=apidojo-yahoo-finance-v1.p.rapidapi.com

# Retail sentiment source (Dukascopy realtime widget API)
SENTIMENT_PROVIDER=dukascopy-realtime
SENTIMENT_PROVIDER_BASE_URL=https://freeserv.dukascopy.com/2.0/api/
SENTIMENT_PROVIDER_WIDGET_KEY=bsq3l3p5lc8w4s0c
SENTIMENT_PROVIDER_TIMEOUT_MS=12000
SENTIMENT_PROVIDER_LIQUIDITY=consumers
SENTIMENT_PROVIDER_TYPE=swfx
SENTIMENT_STALE_AFTER_HOURS=6

# COT data source
COT_PROVIDER=cftc-legacy-futures
COT_PROVIDER_BASE_URL=https://publicreporting.cftc.gov/resource/6dca-aqww.json
COT_PROVIDER_TIMEOUT_MS=12000
COT_PROVIDER_APP_TOKEN=your_optional_socrata_app_token
COT_STALE_AFTER_HOURS=192

# -----------------------------------------------------
# OpenAI (AI summary engine)
# -----------------------------------------------------

# auto = use OpenAI when key exists, otherwise template fallback
AI_SUMMARY_MODE=auto
AI_SUMMARY_MODEL=gpt-4o-mini
AI_SUMMARY_TIMEOUT_MS=12000
OPENAI_API_KEY=your_openai_api_key

# -----------------------------------------------------
# System Configuration
# -----------------------------------------------------

# Vercel Cron sends this as: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=replace_with_a_long_random_secret

ANALYSIS_INTERVAL_HOURS=3
COT_UPDATE_DAY=FRIDAY

# -----------------------------------------------------
# Feature Flags
# -----------------------------------------------------

ENABLE_AI_SUMMARY=true
ENABLE_SENTIMENT=true
ENABLE_COT=true
ENABLE_VOLATILITY_FILTER=true