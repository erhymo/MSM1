{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/analysis",
      "schedule": "0 */3 * * *"
    },
    {
      "path": "/api/cron/alerts/oil",
      "schedule": "5,20,35,50 * * * *"
    },
    {
      "path": "/api/cron/model-review/outcomes",
      "schedule": "40 2 * * *"
    },
    {
      "path": "/api/cron/analysis/history",
      "schedule": "20 0 * * *"
    },
    {
      "path": "/api/cron/model-review/report",
      "schedule": "55 2 * * 0"
    }
  ]
}